-- ============================================================
-- Creatix Solutions - Database Schema
-- MySQL / MariaDB compatible
-- ============================================================

-- CREATE DATABASE IF NOT EXISTS creatix_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
-- USE creatix_db;

-- ============================================================
-- USERS (admin accounts)
-- ============================================================
CREATE TABLE IF NOT EXISTS users (
    id          BIGINT AUTO_INCREMENT PRIMARY KEY,
    email       VARCHAR(255) NOT NULL UNIQUE,
    password    VARCHAR(255) NOT NULL,
    role        ENUM('ADMIN', 'SUPER_ADMIN') NOT NULL DEFAULT 'ADMIN',
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Seed default admin: admin@creatix.com / Admin@123 (BCrypt hash)
INSERT IGNORE INTO users (email, password, role) VALUES
('admin@creatix.com', '$2a$12$LIlnYUVIIoVbSXbTpawcDeTD8JZ0Y9yGb62a0IHSMLKViqfYnqiKG', 'SUPER_ADMIN');

-- ============================================================
-- CONTACT REQUESTS
-- ============================================================
CREATE TABLE IF NOT EXISTS contact_requests (
    id          BIGINT AUTO_INCREMENT PRIMARY KEY,
    name        VARCHAR(100) NOT NULL,
    email       VARCHAR(255) NOT NULL,
    phone       VARCHAR(30),
    message     TEXT NOT NULL,
    service     VARCHAR(100),
    status      ENUM('NEW', 'READ', 'REPLIED') DEFAULT 'NEW',
    created_at  TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ============================================================
-- CALL BOOKINGS
-- ============================================================
CREATE TABLE IF NOT EXISTS call_bookings (
    id                  BIGINT AUTO_INCREMENT PRIMARY KEY,
    name                VARCHAR(100) NOT NULL,
    email               VARCHAR(255) NOT NULL,
    preferred_date      DATE NOT NULL,
    preferred_time      TIME NOT NULL,
    project_description TEXT,
    status              ENUM('PENDING', 'CONFIRMED', 'CANCELLED') DEFAULT 'PENDING',
    created_at          TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- ============================================================
-- TESTIMONIALS
-- ============================================================
CREATE TABLE IF NOT EXISTS testimonials (
    id              BIGINT AUTO_INCREMENT PRIMARY KEY,
    client_name     VARCHAR(100) NOT NULL,
    company         VARCHAR(150),
    review          TEXT NOT NULL,
    rating          TINYINT NOT NULL DEFAULT 5 CHECK (rating BETWEEN 1 AND 5),
    avatar_url      VARCHAR(500),
    is_featured     BOOLEAN DEFAULT FALSE,
    display_order   INT DEFAULT 0,
    created_at      TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

